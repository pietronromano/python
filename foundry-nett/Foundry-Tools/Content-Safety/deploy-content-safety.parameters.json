{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
    "contentVersion": "1.0.0.0",

    /*
     * Parameters for the Azure AI Content Safety deployment.
     * Update "accountName" with a globally unique name before deploying.
     *
     * Deploy with:
     *   az deployment group create \
     *     --resource-group <your-rg> \
     *     --template-file deploy-content-safety.json \
     *     --parameters @deploy-content-safety.parameters.json
     */

    "parameters": {
        "accountName": {
            "value": "foundry-demo-content-safety"
        },
        "location": {
            "value": "eastus2"
        },
        "sku": {
            "value": "S0"
        }
    }
}
