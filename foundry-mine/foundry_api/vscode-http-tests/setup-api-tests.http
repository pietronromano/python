@baseUrl = http://localhost:8000/setup

### Upload a file using multipart/form-data with boundary
# Specify file path to use as a body, which starts with "<"  
# The file path(whitespaces should be preserved) can be either in absolute or relative(relative to workspace root or current http file) formats:

POST {{baseUrl}}/upload_file
Content-Type: multipart/form-data; boundary=----Boundary

------Boundary
Content-Disposition: form-data; name="file"; filename="coffee_shop_sales.csv"
Content-Type: text/csv

< ../../inputs/coffee_shop_sales.csv
------Boundary--

# Example response from the upload_file endpoint:
# {
#   "id": "assistant-26zUX86n4sb7SkiFYSx9FE",
#   "bytes": 1500,
#   "filename": "upload",
#   "purpose": "assistants",
#   "status": "processed",
#   "created_at": 1776964238,
#   "expires_at": null
# }


### Download a file using the file ID returned from the upload_file endpoint
### NOTE: This will give a 400 if it was a code generated file stored in a container, in that case need to also provide the container ID as a query parameter
@file_id = assistant-26zUX86n4sb7SkiFYSx9FE  # Set this variable to the file ID returned from the upload_file response
@filename = coffee_shop_sales.png
GET {{baseUrl}}/download_file?file_id={{file_id}}&filename={{filename}}


### Download a file with a file ID and container ID returned the code tool response if the file is generated by the code tool and stored in a container
@file_id = cfile_69eb1b56c17481908566c48dfa77abba  
@container_id = cntr_69eb1b41d4b08190bd014881c591cb09079cc9601f77f165  
@filename = generated_file.png
GET {{baseUrl}}/download_file?file_id={{file_id}}&container_id={{container_id}}&filename={{filename}}